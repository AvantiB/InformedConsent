{
  "name": "literature_informed_consent_data_use_cues",
  "version": "0.1",
  "description": "Seed cue groups for consent, biobank resource usage, and data sharing meaning-preservation analysis. These are not a complete validated lexicon; they are literature-informed, editable seed categories for ablation and feature analysis.",
  "rationale": {
    "deontic_modality": "Informed consent language often changes meaning through permission, obligation, prohibition, conditionality, and exception cues.",
    "privacy_data_practices": "Biobank/resource-use consent overlaps with privacy-policy and data-practice categories: collection, use, sharing/disclosure, retention/deletion, access, choice/withdrawal, data type, recipient, purpose, and safeguards.",
    "biobank_specific": "Biobank consent adds recurring concepts such as biospecimens, genetic/genomic data, future research, commercial use, return of results, withdrawal, and governance/IRB oversight."
  },
  "references": [
    {
      "key": "LEXDEMOD",
      "title": "Agent-Specific Deontic Modality Detection in Legal Language",
      "url": "https://arxiv.org/abs/2211.12752",
      "notes": "Supports deontic modality categories and trigger-span analysis in legal language."
    },
    {
      "key": "BakerModalityNegation",
      "title": "Modality and negation lexicon/tagger line of work",
      "url": "https://aclanthology.org/",
      "notes": "Supports treating modality/negation cues as trigger vocabularies that can be expanded beyond manual seeds."
    },
    {
      "key": "OPP115",
      "title": "Online Privacy Policies / OPP-115 data-practice categories",
      "url": "https://usableprivacy.org/data",
      "notes": "Supports privacy-policy categories such as collection, sharing, retention, user choice/control, access, and security."
    },
    {
      "key": "DUO",
      "title": "Data Use Ontology",
      "url": "https://github.com/EBISPOT/DUO",
      "notes": "Supports biomedical data-use limitations such as general research use, health/medical/biomedical use, disease-specific use, commercial use restrictions, publication moratorium, and user/institution restrictions."
    }
  ],
